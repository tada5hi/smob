{
    "extends": "@tada5hi/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "noUncheckedIndexedAccess": false
    },
    "include": [
        "src/**/*"
    ]
}
